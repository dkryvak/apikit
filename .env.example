# Copy to .env and adjust. Build-time config — values are baked into the binary
# by `task build` (read by the Taskfile, NOT at runtime). Change a value, rebuild.

# Pod image tag for `apikit kube` (which published image to pull, e.g. latest).
TAG=latest

# Kube Job tuning (seconds), baked at build.
POD_LIFETIME_SECONDS=1800       # pod sleep duration + Job hard cap
JOB_TTL_SECONDS=120             # cleanup after the Job finishes
POD_READY_TIMEOUT_SECONDS=90    # wait-for-pod-ready timeout
