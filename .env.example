# Copy to .env and adjust. Loaded by Taskfile (dotenv) and by the CLI (godotenv).

# Pod image tag for `apikit kube` (which published image to pull, e.g. latest).
# Version (`apikit --version`) comes from git describe locally / the git tag on release, not from TAG.
TAG=latest

# Pod image consumed by `apikit kube`. The tag part comes from TAG above.
IMAGE=ghcr.io/dkryvak/apikit:${TAG}

# Kube Job tuning (seconds). Optional — defaults shown.
POD_LIFETIME_SECONDS=1800       # pod sleep duration + Job hard cap
JOB_TTL_SECONDS=120             # cleanup after the Job finishes
POD_READY_TIMEOUT_SECONDS=90    # wait-for-pod-ready timeout
